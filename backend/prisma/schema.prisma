generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("basic")
  status    String   @default("active")
  createdAt DateTime @default(now())

  whatsappPhone        String?
  evolutionApiUrl      String?
  evolutionApiKey      String?
  evolutionInstance    String?
  reminderTemplate     String?
  confirmationTemplate String?
  peakHours            Json?
  reminderEnabled      Boolean @default(true)
  reminder1Hours       Int     @default(24)
  reminder2Hours       Int     @default(2)
  paymentProvider      String?   // mercadopago | stripe | abacatepay
  mpAccessToken        String?
  stripeSecretKey      String?
  stripeWebhookSecret  String?
  abacatePayApiKey     String?
  paymentFlow          String?   // disabled | deposit | no_show_fee | both
  depositPercent       Int?
  noShowFee            Float?

  users        User[]
  clients      Client[]
  appointments Appointment[]
  waitlist     Waitlist[]
  services     Service[]
  payments     Payment[]
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  email        String
  passwordHash String
  role         String
  weekSchedule Json?
  photoUrl     String?
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
}

model Client {
  id           String    @id @default(uuid())
  tenantId     String
  name         String
  phone        String
  email        String?
  riskScore    Int       @default(0)
  isVip        Boolean   @default(false)
  consentedAt  DateTime?
  passwordHash String?
  createdAt    DateTime  @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  appointments Appointment[]
  waitlist     Waitlist[]
}

model Appointment {
  id             String    @id @default(uuid())
  tenantId       String
  clientId       String
  professionalId String
  service        String
  scheduledAt    DateTime
  status         String    @default("scheduled")
  riskScore      Int       @default(0)
  confirmedAt    DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime  @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  client        Client         @relation(fields: [clientId], references: [id])
  notifications Notification[]
  payments      Payment[]
}

model Payment {
  id              String    @id @default(uuid())
  tenantId        String
  appointmentId   String
  mpPaymentId     String?
  type            String    // deposit | no_show_fee
  amount          Float
  status          String    @default("pending") // pending | approved | rejected | cancelled
  pixQrCode       String?
  pixQrCodeBase64 String?
  createdAt       DateTime  @default(now())
  paidAt          DateTime?

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model Waitlist {
  id             String    @id @default(uuid())
  tenantId       String
  slot           DateTime
  clientId       String
  professionalId String?
  position       Int
  notifiedAt     DateTime?
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  client Client @relation(fields: [clientId], references: [id])
}

model Notification {
  id            String    @id @default(uuid())
  tenantId      String
  appointmentId String
  type          String
  channel       String    @default("whatsapp")
  status        String    @default("pending")
  sentAt        DateTime?
  createdAt     DateTime  @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model Service {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  duration    Int
  price       Float?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model PasswordReset {
  id        String    @id @default(uuid())
  clientId  String
  tenantId  String
  token     String    @unique
  method    String    // whatsapp | email
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String
  ip        String?
  createdAt DateTime @default(now())
}