# Banco de dados
DATABASE_URL="postgresql://noshow:noshow123@localhost:5432/noshow_dev"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
# OBRIGATÓRIO: gere um segredo forte antes de subir em produção
# Comando: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# Servidor
PORT=4000
NODE_ENV=development
# URL do frontend — usada no CORS (em produção, coloque o domínio real)
FRONTEND_URL="http://localhost:3000"

# Super Admin (acesso ao painel /admin)
# Gere o hash com: node -e "require('bcryptjs').hash('sua-senha',10).then(console.log)"
ADMIN_EMAIL="admin@noshow.com"
ADMIN_PASSWORD_HASH=""

# WhatsApp (Evolution API)
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="sua-api-key"
EVOLUTION_INSTANCE="noshow"
