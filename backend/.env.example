# ════════════════════════════════════════════════════════════
# BANCO DE DADOS
# ════════════════════════════════════════════════════════════

DATABASE_URL="postgresql://noshow:noshow123@localhost:5432/noshow_dev"

# ════════════════════════════════════════════════════════════
# REDIS (BullMQ — filas de lembretes)
# ════════════════════════════════════════════════════════════

REDIS_URL="redis://localhost:6379"

# ════════════════════════════════════════════════════════════
# JWT
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ════════════════════════════════════════════════════════════

JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# ════════════════════════════════════════════════════════════
# SERVIDOR
# ════════════════════════════════════════════════════════════

PORT=4000
NODE_ENV=development

# URL do frontend — usada no CORS
# Em produção use o domínio real (múltiplos separados por vírgula)
FRONTEND_URL="http://localhost:3000"

# ════════════════════════════════════════════════════════════
# SUPER ADMIN (painel /admin)
# Hash: node -e "require('bcryptjs').hash('sua-senha',10).then(console.log)"
# ════════════════════════════════════════════════════════════

ADMIN_EMAIL="admin@kired.com.br"
ADMIN_PASSWORD_HASH=""

# ════════════════════════════════════════════════════════════
# WHATSAPP (Evolution API)
# ════════════════════════════════════════════════════════════

EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="noshow-evolution-key-dev"
EVOLUTION_INSTANCE="noshow"

# ════════════════════════════════════════════════════════════
# E-MAIL (SMTP — reset de senha)
# Se não configurado, os e-mails são simulados no console
# ════════════════════════════════════════════════════════════

SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
